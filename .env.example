# 可选：本地开发用。正式演示建议让用户在网页侧边栏自行填写 API Key。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus

# 可选：限制公网 Demo 的单次请求体大小，默认约 1.5MB。
MAX_BODY_BYTES=1500000

# 可选：生产环境可指定允许访问的前端来源。默认 * 适合单体 Demo。
# CORS_ALLOW_ORIGINS=https://your-domain.example.com
CORS_ALLOW_ORIGINS=*
