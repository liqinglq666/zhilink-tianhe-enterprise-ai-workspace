# 当前网页版本由使用者在浏览器侧填写模型 API Key、Base URL 和模型名称。
# 后端不会从 .env 注入或持久化网页用户的模型密钥。

# 可选：限制公网 Demo 的单次请求体大小，默认约 1.5MB。
MAX_BODY_BYTES=1500000

# 可选：生产环境可指定允许访问的前端来源。默认 * 适合单体 Demo。
# CORS_ALLOW_ORIGINS=https://your-domain.example.com
CORS_ALLOW_ORIGINS=*

# 强烈建议：公网部署时限制后端可访问的模型网关域名，使用英文逗号分隔。
# 请按实际使用的供应商增删，不要填写 URL 路径。
LLM_ALLOWED_HOSTS=dashscope.aliyuncs.com,api.openai.com

# 仅限可信的本地开发环境。公网部署不要开启 HTTP 模型网关。
# ALLOW_INSECURE_LLM_HTTP=true
